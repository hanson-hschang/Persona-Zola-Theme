# 1. Global defaults: Handle line endings automatically
* text=auto

# 2. Shell Scripts: Force LF and ensure they are treated as executable
# This tells Git to default these to 100755 mode on Unix systems.
scripts/*.sh text eol=lf
scripts/*.sh executable

# 3. Git LFS for Images: Keep images out of the main repo history to save space
# Use '-text' to ensure Git never tries to "fix" line endings in binary files.
static/assets/img/** filter=lfs diff=lfs merge=lfs -text
content/**/img/**    filter=lfs diff=lfs merge=lfs -text
*.jpg                filter=lfs diff=lfs merge=lfs -text
*.png                filter=lfs diff=lfs merge=lfs -text
*.gif                filter=lfs diff=lfs merge=lfs -text

# 4. Data files: Ensure Bibliography and CSL are handled as text
*.bib text
*.csl text

# 5. Content: Treat Markdown as text with LF
*.md text eol=lf
*.src.md text eol=lf